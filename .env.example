# AI Content Machine — Environment Variables
# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: path to store voice documents and posts
# Defaults to ./voices relative to backend directory
VOICES_PATH=voices

# Optional: Buffer API for scheduling
BUFFER_ACCESS_TOKEN=your_buffer_token_here

# Optional: Tavily API for real-time web search in Research Mode
# Free tier: 1,000 searches/month — https://tavily.com
# Without this key, Research Mode falls back to Claude's training data (clearly flagged in UI)
TAVILY_API_KEY=tvly-your_key_here

# Optional: for X monitoring (narrative hijacking)
X_BEARER_TOKEN=your_x_bearer_token_here

# Optional: for performance tracking
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
